# =============================================
# Configuracao do Bot Discord RAG
# Copie este arquivo para .env e preencha os valores
# =============================================

# Discord
DISCORD_TOKEN=seu_token_aqui
COMMAND_PREFIX=!
BOT_NAME=Assistente

# Google Gemini (LLM + embeddings)
GEMINI_API_KEY=sua_chave_gemini_aqui
GEMINI_MODEL=gemini-2.5-pro
REFORMULATION_MODEL=gemini-2.5-flash
EMBEDDING_MODEL=gemini-embedding-001
# Provider ativo: gemini ou openai
LLM_PROVIDER=gemini
# Se vazio, usa o mesmo valor de LLM_PROVIDER
EMBEDDING_PROVIDER=
# OpenAI (preencha para usar provider openai)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-5.4
OPENAI_REFORMULATION_MODEL=gpt-5.4-mini
OPENAI_CONTEXTUAL_MODEL=gpt-5.4-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
# 1536 (recomendado) ou 3072 (se seu pgvector suportar)
EMBEDDING_DIMENSIONS=1536
EMBEDDING_BATCH_SIZE=10
EMBEDDING_MAX_RETRIES=8
EMBEDDING_RETRY_BASE_SECONDS=5
EMBEDDING_RETRY_MAX_SECONDS=65
EMBEDDING_MIN_INTERVAL_SECONDS=0.5
EMBEDDING_RETRY_JITTER_SECONDS=0.5

# PostgreSQL
DATABASE_URL=postgresql://bot_maxima:bot_maxima@postgres:5432/bot_maxima
DB_POOL_MIN_SIZE=1
DB_POOL_MAX_SIZE=8
DB_POOL_TIMEOUT_SECONDS=10
DB_STATEMENT_TIMEOUT_MS=15000
DB_LOCK_TIMEOUT_MS=5000
DB_IDLE_IN_TRANSACTION_TIMEOUT_MS=15000
DB_APPLICATION_NAME=bot-maxima

# RAG
CHUNK_SIZE=1200
CHUNK_OVERLAP=300
MAX_CONTEXT_CHUNKS=24
SIMILARITY_THRESHOLD=0.40
RAG_ENABLE_INTENT_ROUTING=true
RAG_FILTER_BY_DOC_TYPE=true
RAG_FILTER_BY_MODULE=true
RAG_ENABLE_BUSINESS_RULES=true
ANALYTICAL_CONTEXT_ENABLED=true
BUSINESS_RULES_FILE=./bootstrap/00-DOCUMENTO-PRINCIPAL.md
BUSINESS_RULES_MAX_CHARS=20000
FULL_CONTEXT_ENABLED=false
RAG_ENABLE_QUERY_REFORMULATION=true
RAG_ENABLE_RERANKING=true
RERANKER_MODEL=gemini-2.5-flash
RERANKER_MAX_CANDIDATES=40
RERANKER_MIN_TRIGGER_SIM=0.55
RERANKER_MAX_TRIGGER_SIM=0.82
SECTION_RETRIEVAL_ENABLED=true
SECTION_MATCH_COUNT=12
SECTION_FETCH_LIMIT=48
CHUNK_FETCH_LIMIT=80
MAX_CHUNKS_PER_SECTION=3
MAX_CHUNKS_PER_DOCUMENT=6
RAG_STRICT_ABSTAIN=true
RAG_MIN_STRONG_SIMILARITY=0.42
RAG_MIN_RETRIEVED_CHUNKS=2
RAG_OPERATIONAL_SIMILARITY_MARGIN=0.03
RAG_ENABLE_GROUNDING_VALIDATION=true
RAG_REQUIRE_SOURCES_SECTION=true
RAG_MAX_REGEN_ATTEMPTS=2
RAG_FEEDBACK_TOP_K=4
RAG_FEEDBACK_MIN_SIMILARITY=0.58
ABSTAIN_CLARIFYING_QUESTION=Pode detalhar o modulo, a tela/parametro e a mensagem de erro exata para eu buscar com mais precisao?

# Bot â€” limites
COOLDOWN_SECONDS=10
ASK_TIMEOUT_SECONDS=240
ASK_MAX_TOKENS=16384
OPENAI_MAX_OUTPUT_TOKENS=16384
MAX_HISTORY_PAIRS=12
MAX_HISTORY_CHANNELS=100

# Microsoft Teams (opcional - preencha para usar bot_teams.py)
# Crie em: Azure Portal > Azure Bot > App Registration
TEAMS_APP_ID=seu-app-id-do-azure
TEAMS_APP_PASSWORD=seu-app-password-do-azure
TEAMS_TENANT_ID=seu-tenant-id-do-azure
TEAMS_ADMIN_IDS=
TEAMS_PORT=3978
TEAMS_MANIFEST_SHORT_NAME=Assistente RAG
TEAMS_MANIFEST_FULL_NAME=Assistente de Documentos com IA
TEAMS_MANIFEST_SHORT_DESCRIPTION=Pergunte sobre documentos da base de conhecimento
TEAMS_MANIFEST_FULL_DESCRIPTION=Bot assistente que consulta a base de documentos da empresa usando IA. Envie uma pergunta e receba respostas baseadas nos documentos indexados, com citacao das fontes.
TEAMS_MANIFEST_DEVELOPER_NAME=Sua Empresa
TEAMS_MANIFEST_DEVELOPER_WEBSITE_URL=https://sua-empresa.com
TEAMS_MANIFEST_DEVELOPER_PRIVACY_URL=https://sua-empresa.com/privacidade
TEAMS_MANIFEST_DEVELOPER_TERMS_URL=https://sua-empresa.com/termos
TEAMS_MANIFEST_ACCENT_COLOR=#4F46E5
TEAMS_MANIFEST_SHORT_NAME=Assistente RAG
TEAMS_MANIFEST_FULL_NAME=Assistente de Documentos com IA
TEAMS_MANIFEST_SHORT_DESCRIPTION=Pergunte sobre documentos da base de conhecimento
TEAMS_MANIFEST_FULL_DESCRIPTION=Bot assistente que consulta a base de documentos da empresa usando IA. Envie uma pergunta e receba respostas baseadas nos documentos indexados, com citacao das fontes.
TEAMS_MANIFEST_DEVELOPER_NAME=Sua Empresa
TEAMS_MANIFEST_DEVELOPER_WEBSITE_URL=https://sua-empresa.com
TEAMS_MANIFEST_DEVELOPER_PRIVACY_URL=https://sua-empresa.com/privacidade
TEAMS_MANIFEST_DEVELOPER_TERMS_URL=https://sua-empresa.com/termos
TEAMS_MANIFEST_ACCENT_COLOR=#4F46E5

# Documentos
DOCS_DIR=./documentos
FAILED_INGEST_REPORT=./ingest_failures.json
INGEST_RECURSIVE=true

# Ingestao web (URLs)
WEB_FETCH_TIMEOUT_SECONDS=20
WEB_USER_AGENT=BotMaximaRAG/1.0
WEB_MAX_TEXT_CHARS=400000
URLS_FILE_DEFAULT=./documentos/urls.txt
URL_REVIEW_OUTPUT_DIR=./documentos/_pendentes_url

# LangExtract (opcional - extracao estruturada)
LANGEXTRACT_ENABLED=false
# Se vazio, usa GEMINI_API_KEY
LANGEXTRACT_API_KEY=
LANGEXTRACT_MODEL_ID=gemini-2.5-flash
LANGEXTRACT_PROMPT_DESCRIPTION=Extraia fatos tecnicos e operacionais para RAG de suporte: parametros, campos, tabelas, endpoints, metodos HTTP, regras de validacao, codigos de erro, procedimentos passo a passo, dependencias e integracoes ERP.
LANGEXTRACT_EXAMPLES_FILE=./documentos/langextract_examples.json
LANGEXTRACT_EXTRACTION_PASSES=1
LANGEXTRACT_MAX_WORKERS=4
LANGEXTRACT_MAX_CHAR_BUFFER=1800
LANGEXTRACT_APPEND_RAW_TEXT=true
LANGEXTRACT_MAX_FACTS=300

# Contextual Retrieval (enriquece chunks com contexto antes do embedding)
# Melhora retrieval em -35% a -67% segundo benchmarks
CONTEXTUAL_RETRIEVAL_ENABLED=true
CONTEXTUAL_RETRIEVAL_MODEL=gemini-2.5-flash
CONTEXTUAL_RETRIEVAL_MAX_DOC_CHARS=500000
CONTEXTUAL_RETRIEVAL_MAX_TOKENS=250
CONTEXTUAL_RETRIEVAL_BATCH_SIZE=20

# Revisao manual (_pendentes_url)
REVIEW_INCLUDE_RAW_TEXT=true
REVIEW_RAW_TEXT_MAX_CHARS=120000

# Jira - extracao Gatekeeper
# Alias opcional para JIRA_BASE_URL
JIRA_URL=
JIRA_BASE_URL=https://suporte.maximatech.com.br
# Aceita tambem USERNAME como alias, mas prefira JIRA_USERNAME
JIRA_USERNAME=
# Aceita autenticacao basica com senha quando o Jira nao usa token
JIRA_PASSWORD=
JIRA_API_TOKEN=
# Alternativa a usuario/token: cookie bruto da sessao autenticada
JIRA_SESSION_COOKIE=
# Aliases extras do responsavel atual, separados por | , ; ou em JSON
JIRA_ASSIGNEE_ALIASES=Filipe do Amaral Padilha|Felipe do Amaral Padilha
JIRA_USER_SEARCH_PATH=/rest/api/2/user/search
JIRA_REQUEST_TIMEOUT_SECONDS=60
