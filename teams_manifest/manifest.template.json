{
  "$schema": "https://developer.microsoft.com/en-us/json-schemas/teams/v1.19/MicrosoftTeams.schema.json",
  "manifestVersion": "1.19",
  "version": "1.0.0",
  "id": "__TEAMS_APP_ID__",
  "developer": {
    "name": "__TEAMS_MANIFEST_DEVELOPER_NAME__",
    "websiteUrl": "__TEAMS_MANIFEST_DEVELOPER_WEBSITE_URL__",
    "privacyUrl": "__TEAMS_MANIFEST_DEVELOPER_PRIVACY_URL__",
    "termsOfUseUrl": "__TEAMS_MANIFEST_DEVELOPER_TERMS_URL__"
  },
  "icons": {
    "color": "color.png",
    "outline": "outline.png"
  },
  "name": {
    "short": "__TEAMS_MANIFEST_SHORT_NAME__",
    "full": "__TEAMS_MANIFEST_FULL_NAME__"
  },
  "description": {
    "short": "__TEAMS_MANIFEST_SHORT_DESCRIPTION__",
    "full": "__TEAMS_MANIFEST_FULL_DESCRIPTION__"
  },
  "accentColor": "__TEAMS_MANIFEST_ACCENT_COLOR__",
  "bots": [
    {
      "botId": "__TEAMS_APP_ID__",
      "scopes": [
        "personal",
        "team",
        "groupChat"
      ],
      "supportsFiles": false,
      "isNotificationOnly": false,
      "commandLists": [
        {
          "scopes": [
            "personal",
            "team",
            "groupChat"
          ],
          "commands": [
            {
              "title": "ajuda",
              "description": "Mostra os comandos disponiveis"
            },
            {
              "title": "status",
              "description": "Estatisticas da base de conhecimento"
            },
            {
              "title": "fontes",
              "description": "Lista documentos indexados"
            },
            {
              "title": "limpar",
              "description": "Limpa historico de conversa"
            },
            {
              "title": "ping",
              "description": "Verifica se o bot esta ativo"
            }
          ]
        }
      ]
    }
  ],
  "permissions": [
    "identity",
    "messageTeamMembers"
  ],
  "validDomains": []
}
