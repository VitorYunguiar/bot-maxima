            "avatarUrls": {
              "48x48": "https://suporte.maximatech.com.br/secure/useravatar?ownerId=filipe.padilha&avatarId=17111",
              "24x24": "https://suporte.maximatech.com.br/secure/useravatar?size=small&ownerId=filipe.padilha&avatarId=17111",
              "16x16": "https://suporte.maximatech.com.br/secure/useravatar?size=xsmall&ownerId=filipe.padilha&avatarId=17111",
              "32x32": "https://suporte.maximatech.com.br/secure/useravatar?size=medium&ownerId=filipe.padilha&avatarId=17111"
            },
            "displayName": "Filipe do Amaral Padilha",
